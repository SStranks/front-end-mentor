{
  "extends": "./tsconfig.base.json",
  "include": ["server/tests/*", "server/**/*.test.*", "server/**/*.spec.*", "global.d.ts"],
  "exclude": ["node_modules", "server/**/private*", "**/private/*"],
  "references": [{ "path": "./tsconfig.src.json" }],
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "types": ["vitest/globals", "node"]
  }
}
