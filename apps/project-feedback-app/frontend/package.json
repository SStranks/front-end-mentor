    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.11",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.18.0",
    "react-transition-group": "^4.4.5",
    "rollbar": "^2.26.2"
  },
  "devDependencies": {
    "@packages/babel-config": "workspace:*",
    "@packages/jest-config-react": "workspace:^",
