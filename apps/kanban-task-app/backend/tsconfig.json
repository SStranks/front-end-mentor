{
  "extends": "@packages/typescript-config/nodejs",
  "compilerOptions": {
    "baseUrl": "./server",
    "paths": {
      "#Shared/*": ["../../shared/*"],
      "#Config/*": ["config/*"],
      "#Controllers/*": ["controllers/*"],
      "#Models/*": ["models/*"],
      "#Routes/*": ["routes/*"],
      "#Utils/*": ["utils/*"]
    }
  },
  "include": ["server/**/*.ts", "dist"],
  "exclude": ["node_modules"]
}
