{
  "extends": "@packages/typescript-config/react",
  "compilerOptions": {
    "paths": {
      "@Shared/*": ["../shared/*"],
      "@Img/*": ["./src/assets/img/*"],
      "@Sass/*": ["./src/assets/sass/*"],
      "@Svg/*": ["./src/assets/svg/*"],
      "@Components/*": ["./src/components/*"],
      "@Context/*": ["./src/context/*"],
      "@Config/*": ["./src/config/*"],
      "@Data/*": ["./src/data/*"],
      "@Features/*": ["./src/features/*"],
      "@Hooks/*": ["./src/hooks/*"],
      "@Layouts/*": ["./src/layouts/*"],
      "@Lib/*": ["./src/lib/*"],
      "@Pages/*": ["./src/pages/*"],
      "@Services/*": ["./src/services/*"],
      "@Types/*": ["./src/types/*"],
      "@Utils/*": ["./src/utils/*"]
    },
    "types": ["node"]
  },
  "exclude": ["node_modules", "public", "dist"]
}
