{
  "extends": "../tsconfig.base.json",
  "include": ["**/*"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": ["node", "webpack"]
  }
}
